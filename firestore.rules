rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - username: string (required)
    //   - role: string (required, 'admin' or 'member')
    //   - email: string (required)
    //
    // Collection: accounts
    // Document ID: {accountId}
    // Fields:
    //   - gmail: string (required)
    //   - password: string (required)
    //   - twoFactor: string (optional)
    //   - status: string (required, 'Ok' or 'Pending')
    //   - createdBy: string (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "r2.70xz@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'role', 'email']) &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.role in ['admin', 'member'] &&
             data.email is string;
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['gmail', 'password', 'status', 'createdBy', 'createdAt']) &&
             data.gmail is string && data.gmail.size() > 0 && data.gmail.size() < 255 &&
             data.password is string && data.password.size() > 0 && data.password.size() < 255 &&
             data.status in ['Ok', 'Pending'] &&
             data.createdBy is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    match /accounts/{accountId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAccount(request.resource.data);
      allow update: if isAuthenticated() && isValidAccount(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
